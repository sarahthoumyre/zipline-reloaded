from collections import defaultdict
import pandas as pd
from datetime import datetime

class Portfolio:
    def __init__(self, cash: float, data: MarketData):
        self.cash_operational = cash
        self.cash_interest = 0.0
        self.interest_rate = 0.0
        self.last_cash_operational = cash

        self.order_book = defaultdict(lambda: {"orders": {}})
        self.positions = defaultdict(float)
        self.order_executed = {}
        self.cost_basis = defaultdict(float)
        self.entry_price = defaultdict(float)

        self.portfolio_value = pd.Series(dtype=float)
        self.cash_value = pd.Series(dtype=float)
        self.last_update_date = None
        self.current_date = None
        self.data = data

    def set_current_date(self, date: datetime):
        self.last_update_date = self.current_date
        self.current_date = date

    def add_order(self, instrument, amount: float, rebalancing_date: datetime, review_date: datetime = None):
        review_date = review_date or rebalancing_date
        self.order_book[review_date]["orders"][instrument] = {
            "amount": amount,
            "date": rebalancing_date
        }

    def execute_orders(self):
        date = self.current_date
        if date not in self.order_book:
            self.order_executed = {}
            return

        self.order_executed = {}
        for instrument, order in self.order_book[date]["orders"].items():
            price = self.data.get_price(date, instrument.id)
            quantity = order["amount"] / price

            self.positions[instrument] += quantity
            self.cash_operational -= quantity * price
            self.order_executed[instrument] = quantity

            # Mise à jour du cost_basis
            total_qty = self.positions[instrument]
            prev_cost = self.cost_basis[instrument]
            self.cost_basis[instrument] = (
                ((prev_cost * (total_qty - quantity)) + (price * quantity)) / total_qty
            )

        del self.order_book[date]

    def update_portfolio_value(self, date: datetime):
        total_value = self.cash_operational
        for instrument, qty in self.positions.items():
            price = self.data.get_price(date, instrument.id)
            total_value += qty * price
        self.portfolio_value[date] = total_value
        self.cash_value[date] = self.cash_operational
        self.last_update_date = date

    def get_portfolio_market_value(self, date: datetime) -> float:
        total_value = self.cash_operational
        for instrument, qty in self.positions.items():
            price = self.data.get_price(date, instrument.id)
            total_value += qty * price
        return total_value





class Strategy:
    def __init__(self, capital_base: float, initialize=None, handle_data=None,
                 strategy_calendar: StrategyCalendar = None, market_data: MarketData = None):
        self.capital_base = capital_base
        self.initialize = initialize
        self.handle_data = handle_data
        self.strategy_calendar = strategy_calendar
        self.market_data = market_data
        self.portfolio = Portfolio(cash=capital_base, data=market_data)
        self.performance_history = pd.DataFrame()

    def run_algorithm(self) -> pd.DataFrame:
        if self.initialize:
            self.initialize(self)

        timeline = self.strategy_calendar.get_merged_index()

        for dt in timeline:
            self.portfolio.set_current_date(dt)

            if self.handle_data:
                self.handle_data(self, dt)

            self.portfolio.execute_orders()
            self.portfolio.update_portfolio_value(dt)

            row = {}

            # Q
            for instrument, qty in self.portfolio.positions.items():
                row[f"{instrument.id} Q"] = qty

            # orders
            for instrument, qty in self.portfolio.order_executed.items():
                row[f"{instrument.id} orders"] = qty

            # market price
            for instrument in self.portfolio.positions:
                price = self.market_data.get_price(dt, instrument.id)
                row[f"{instrument.id} market price"] = price

            # cash interest
            row["cash interest"] = self.portfolio.cash_interest

            # cash flow
            current_cash = self.portfolio.cash_operational
            row["cash flow"] = current_cash - self.portfolio.last_cash_operational
            self.portfolio.last_cash_operational = current_cash

            # cost_basis
            for instrument, cb in self.portfolio.cost_basis.items():
                row[f"{instrument.id} cost_basis"] = cb

            # entry_price (non utilisé pour l’instant, mais structure prête)
            for instrument, ep in self.portfolio.entry_price.items():
                row[f"{instrument.id} entry_price"] = ep

            row["timestamp"] = dt
            row["strategy_value"] = self.strategy_value(dt)

            self.performance_history = pd.concat(
                [self.performance_history, pd.DataFrame([row])], ignore_index=True
            )

        return self.performance_history

    def strategy_value(self, dt: datetime) -> float:
        return self.portfolio.get_portfolio_market_value(dt)
