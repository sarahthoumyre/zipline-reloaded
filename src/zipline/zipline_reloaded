from collections import defaultdict
import pandas as pd
from datetime import datetime

class Portfolio:
    def __init__(self, cash: float, data):
        self.cash_operational = cash
        self.cash_interest = 0.0
        self.last_cash_operational = cash

        self.data = data  # MarketData object
        self.order_book = defaultdict(lambda: {"orders": {}})
        self.positions = defaultdict(float)
        self.order_executed = defaultdict(float)
        self.cost_basis = defaultdict(float)
        self.entry_price = defaultdict(float)

        self.portfolio_value = pd.Series(dtype=float)
        self.cash_value = pd.Series(dtype=float)
        self.position_value = pd.Series(dtype=float)

        self.fx_used = {}  # date: {fx_pair: rate}
        self.current_date = None

    def set_current_date(self, date: datetime):
        self.current_date = date

    def add_order_amount(self, instrument, amount: float, rebalancing_date: datetime, review_date: datetime = None):
        date = review_date or rebalancing_date
        self.order_book[date]["orders"][instrument] = {
            "amount": amount,
            "date": rebalancing_date,
            "mode": "amount"
        }

    def add_order_quantity(self, instrument, quantity: float, rebalancing_date: datetime, review_date: datetime = None):
        date = review_date or rebalancing_date
        self.order_book[date]["orders"][instrument] = {
            "quantity": quantity,
            "date": rebalancing_date,
            "mode": "quantity"
        }

    def execute_orders(self):
        date = self.current_date
        if date not in self.order_book:
            return

        fx_today = {}
        for instrument, order in self.order_book[date]["orders"].items():
            price = self.data.get_price(date, instrument, folder_path='Data')

            # Récupère et enregistre le FX si besoin
            if instrument.denomination_currency != self.data.strategy_currency:
                fx_key = f"{instrument.denomination_currency}_{self.data.strategy_currency}"
                fx_rate = self.data.get_fx_rate(
                    instrument.denomination_currency,
                    self.data.strategy_currency,
                    date,
                    folder_path='Data'
                )
                fx_today[fx_key] = fx_rate

            if order["mode"] == "quantity":
                quantity = order["quantity"]
                amount = quantity * price
            else:
                amount = order["amount"]
                quantity = amount / price

            self.positions[instrument] += quantity
            self.cash_operational -= amount
            self.order_executed[instrument] = quantity

            total_qty = self.positions[instrument]
            prev_cost = self.cost_basis[instrument]
            self.cost_basis[instrument] = (
                (prev_cost * (total_qty - quantity) + (price * quantity)) / total_qty
                if total_qty != 0 else 0
            )
            self.entry_price[instrument] = price

        del self.order_book[date]
        if fx_today:
            self.fx_used[date] = fx_today

    def update_portfolio_value(self, date: datetime):
        total_position_value = 0.0
        for instrument, qty in self.positions.items():
            price = self.data.get_price(date, instrument, folder_path='Data')
            total_position_value += qty * price

        self.cash_value[date] = self.cash_operational
        self.position_value[date] = total_position_value
        self.portfolio_value[date] = self.cash_operational + total_position_value

    def get_portfolio_market_value(self, date: datetime) -> float:
        value = self.cash_operational
        for instrument, qty in self.positions.items():
            price = self.data.get_price(date, instrument, folder_path='Data')
            value += qty * price
        return value

    def get_state_snapshot(self, date: datetime) -> dict:
        snapshot = {
            "date": date,
            "strategy_value": self.get_portfolio_market_value(date),
            "positions": {inst.id: qty for inst, qty in self.positions.items()},
            "orders": {inst.id: qty for inst, qty in self.order_executed.items()},
            "market_price": {inst.id: self.data.get_price(date, inst, folder_path='Data') for inst in self.positions},
            "entry_price": {inst.id: self.entry_price[inst] for inst in self.positions},
            "cost_basis": {inst.id: self.cost_basis[inst] for inst in self.positions},
            "cash_interest": self.cash_interest,
            "cash_flow": self.cash_operational - self.last_cash_operational
        }
        self.last_cash_operational = self.cash_operational
        return snapshot
