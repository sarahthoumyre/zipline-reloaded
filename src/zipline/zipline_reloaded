class Strategy:
    def __init__(self, portfolio: Portfolio, calendar):
        self.portfolio = portfolio
        self.calendar = calendar
        self.history = []

    def run(self):
        for date in self.calendar.get_index():
            self.portfolio.set_current_date(date)
            self.portfolio.execute_orders()
            self.portfolio.update_portfolio_value(date)

    def export_to_excel(self, filename='results.xlsx'):
        import pandas as pd

        df_main = pd.DataFrame({
            'Date': self.portfolio.portfolio_value.index,
            'cash_value': self.portfolio.cash_value,
            'position_value': self.portfolio.position_value,
            'total_value': self.portfolio.portfolio_value,
        }).set_index('Date')

        # Ajout des colonnes FX
        all_fx_keys = set()
        for fx_dict in self.portfolio.fx_used.values():
            all_fx_keys.update(fx_dict.keys())

        for fx in sorted(all_fx_keys):
            df_main[fx] = [
                self.portfolio.fx_used.get(date, {}).get(fx, None)
                for date in df_main.index
            ]

        # Export principal + FX pages
        with pd.ExcelWriter(filename) as writer:
            df_main.to_excel(writer, sheet_name='Strategy')

            # Export de chaque fx dans une feuille à part
            for fx_key in sorted(all_fx_keys):
                df_fx = pd.DataFrame({
                    'Date': df_main.index,
                    'rate': df_main[fx_key]
                }).dropna()
                df_fx.to_excel(writer, sheet_name=fx_key, index=False)
