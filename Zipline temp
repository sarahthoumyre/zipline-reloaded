import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.mixture import GaussianMixture
from hmmlearn.hmm import GaussianHMM

# ----------------------------
# 1. Charger les données
# ----------------------------
# Remplacer par le nom de ton fichier Excel
file_path = "tes_donnees_vx_vvx.xlsx"
df = pd.read_excel(file_path)

# Assurer le bon format
df = df.dropna(subset=["VX", "VVX"])
X = df[["VX", "VVX"]].values

# ----------------------------
# 2. K-Means
# ----------------------------
kmeans = KMeans(n_clusters=2, random_state=0).fit(X)
df["Cluster_KMeans"] = kmeans.labels_

# ----------------------------
# 3. GMM
# ----------------------------
gmm = GaussianMixture(n_components=2, random_state=0).fit(X)
df["Cluster_GMM"] = gmm.predict(X)

# ----------------------------
# 4. HMM
# ----------------------------
hmm_model = GaussianHMM(n_components=2, covariance_type="full", n_iter=100, random_state=0)
hmm_model.fit(X)
df["Cluster_HMM"] = hmm_model.predict(X)

# ----------------------------
# 5. Visualisation
# ----------------------------
fig, axs = plt.subplots(1, 3, figsize=(18, 5))

axs[0].scatter(df["VX"], df["VVX"], c=df["Cluster_KMeans"], cmap='viridis')
axs[0].set_title("K-Means Clustering")
axs[0].set_xlabel("VX")
axs[0].set_ylabel("VVX")

axs[1].scatter(df["VX"], df["VVX"], c=df["Cluster_GMM"], cmap='viridis')
axs[1].set_title("Gaussian Mixture Model")
axs[1].set_xlabel("VX")
axs[1].set_ylabel("VVX")

axs[2].scatter(df["VX"], df["VVX"], c=df["Cluster_HMM"], cmap='viridis')
axs[2].set_title("Hidden Markov Model")
axs[2].set_xlabel("VX")
axs[2].set_ylabel("VVX")

plt.tight_layout()
plt.show()




