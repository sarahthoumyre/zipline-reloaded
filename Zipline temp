import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression
from sklearn.metrics import r2_score

# Charger les données
df = pd.read_excel("tes_donnees.xlsx")  # colonnes : 'Date', 'SPX', 'VSTN'
df["Date"] = pd.to_datetime(df["Date"])
df = df.sort_values("Date").reset_index(drop=True)

# Calcul des rendements journaliers
df["SPX_return"] = df["SPX"].pct_change()

# Liste pour stocker la vol réalisée sur 9 jours calendaires
realized_vol_9d_cal = []

for i in range(len(df)):
    date_j = df.loc[i, "Date"]
    end_date = date_j + pd.Timedelta(days=9)  # j+9 calendaires

    # Extraire les rendements entre j+1 et j+9 calendaires (jours de bourse seulement)
    mask = (df["Date"] > date_j) & (df["Date"] <= end_date)
    future_returns = df.loc[mask, "SPX_return"]

    if len(future_returns) >= 5:  # on garde les cas où il y a assez de jours
        vol = np.std(future_returns, ddof=0) * np.sqrt(252)  # annualisée
    else:
        vol = np.nan
    realized_vol_9d_cal.append(vol)

# Ajouter la colonne au DataFrame
df["realized_vol_9d_calendar"] = realized_vol_9d_cal

# Garder uniquement les lignes valides
df_corr = df.dropna(subset=["VSTN", "realized_vol_9d_calendar"])

# Régression sans intercept
X = df_corr["VSTN"].values.reshape(-1, 1)
y = df_corr["realized_vol_9d_calendar"].values
reg = LinearRegression(fit_intercept=False).fit(X, y)
y_pred = reg.predict(X)
r2 = r2_score(y, y_pred)
corr = df_corr["VSTN"].corr(df_corr["realized_vol_9d_calendar"])

# Résultats
print(f"Corrélation : {corr:.4f}")
print(f"Coefficient (sans intercept) : {reg.coef_[0]:.4f}")
print(f"R² : {r2:.4f}")

# Graphique
plt.figure(figsize=(8, 6))
plt.scatter(X, y, alpha=0.6, label="Points")
plt.plot(X, y_pred, color="red", label=f"Régression (R² = {r2:.2f})")
plt.title("VSTN vs Vol réalisée (9 jours calendaires)")
plt.xlabel("VSTN (vol implicite)")
plt.ylabel("Vol réalisée (SPX, j+1 à j+9 calendaires)")
plt.grid(True)
plt.legend()
plt.tight_layout()
plt.show()






T=Time to expiration (in years)
Cela signifie que le nombre de jours avant l'expiration des options utilisées dans le calcul est converti en années. Et cette conversion, selon les pratiques de marché et les documents techniques du Cboe, se fait en divisant par 365, soit :


