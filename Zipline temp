import pandas as pd
import numpy as np
from sklearn.cluster import KMeans
from sklearn.mixture import GaussianMixture
from hmmlearn.hmm import GaussianHMM
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

# Charger les données
df = pd.read_excel("tes_donnees.xlsx")  # colonnes : 'VSTN', 'VIX', 'SPX'
df = df.sort_values("Date").reset_index(drop=True)
df["SPX_return"] = df["SPX"].pct_change()

# Calcul de la vol return 6 jours (écart-type des rendements sur 6 jours)
df["vol_return_6d"] = df["SPX_return"].rolling(6).std().shift(-5) * np.sqrt(252)

# Supprimer les lignes incomplètes
df_clust = df.dropna(subset=["VSTN", "VIX", "vol_return_6d"])

# Matrice X pour clustering
X = df_clust[["VSTN", "VIX", "vol_return_6d"]].values

# === 1. K-Means ===
kmeans = KMeans(n_clusters=2, random_state=0).fit(X)
df_clust["cluster_kmeans"] = kmeans.labels_

# === 2. GMM ===
gmm = GaussianMixture(n_components=2, random_state=0).fit(X)
df_clust["cluster_gmm"] = gmm.predict(X)

# === 3. HMM ===
hmm = GaussianHMM(n_components=2, covariance_type="full", random_state=0).fit(X)
df_clust["cluster_hmm"] = hmm.predict(X)

# === AFFICHAGE 3D ===
def plot_3d(df, cluster_col, title):
    fig = plt.figure(figsize=(10, 6))
    ax = fig.add_subplot(111, projection='3d')
    scatter = ax.scatter(df["VSTN"], df["VIX"], df["vol_return_6d"],
                         c=df[cluster_col], cmap="coolwarm", alpha=0.7)
    ax.set_xlabel("VSTN")
    ax.set_ylabel("VIX")
    ax.set_zlabel("Volatility Return 6d")
    ax.set_title(title)
    plt.tight_layout()
    plt.show()

plot_3d(df_clust, "cluster_kmeans", "K-Means Clustering (3D)")
plot_3d(df_clust, "cluster_gmm", "Gaussian Mixture Model (3D)")
plot_3d(df_clust, "cluster_hmm", "Hidden Markov Model (3D)")





