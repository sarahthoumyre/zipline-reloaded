class MarketData:
    def __init__(self, instruments: list[Stock], calendar: StrategyCalendar, base_currency: str = "USD"):
        self.instruments = instruments
        self.Calendar = calendar
        self.base_currency = base_currency
        self.prices = {}  # {instrument: DataFrame}
        self.fx_rates = {}  # {("USD", "EUR"): DataFrame}

        for instrument in instruments:
            self.prices[instrument] = self.data_extraction_datascope(instrument)

            # Si devise différente, on extrait les taux de change
            if instrument.denomination_currency != self.base_currency:
                fx_pair = (instrument.denomination_currency, self.base_currency)
                self.fx_rates[fx_pair] = self.extract_fx_rates(fx_pair)

    def extract_fx_rates(self, fx_pair: tuple) -> pd.DataFrame:
        """
        Tu implémentes cette méthode toi-même.
        Elle doit retourner un DataFrame avec 'Date' et 'FX' (le taux de conversion).
        """
        raise NotImplementedError

    def get_price(self, bar: datetime, instrument: Stock) -> float:
        df = self.prices[instrument]
        df['Date'] = pd.to_datetime(df['Date'])
        price = df.loc[df['Date'].dt.date == bar.date(), 'PX_LAST'].iloc[0]

        # Conversion si devise différente
        if instrument.denomination_currency != self.base_currency:
            fx = self.get_fx_rate(bar, instrument.denomination_currency, self.base_currency)
            return price * fx
        return price

    def get_fx_rate(self, bar: datetime, from_currency: str, to_currency: str) -> float:
        fx_df = self.fx_rates[(from_currency, to_currency)]
        fx_df['Date'] = pd.to_datetime(fx_df['Date'])
        rate = fx_df.loc[fx_df['Date'].dt.date == bar.date(), 'FX'].iloc[0]
        return rate
