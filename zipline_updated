class MarketData:
    def __init__(self, instruments: list[Stock], calendar: StrategyCalendar, base_currency: str = "USD"):
        self.instruments = instruments
        self.Calendar = calendar
        self.base_currency = base_currency
        self.cache = {}  # stockage des données par {source}/{id}

        for instrument in instruments:
            key = f"{instrument.source}/{instrument.id}"
            self.cache[key] = self.data_extraction_datascope(instrument)

            # Si devise différente, charger FX
            if instrument.denomination_currency != self.base_currency:
                fx_key = f"FX/{instrument.denomination_currency}/{self.base_currency}"
                if fx_key not in self.cache:
                    self.cache[fx_key] = self.extract_fx_rates(
                        from_currency=instrument.denomination_currency,
                        to_currency=self.base_currency
                    )

    def extract_fx_rates(self, from_currency: str, to_currency: str) -> pd.DataFrame:
        """
        À implémenter toi-même. 
        Retourne un DataFrame avec colonnes : 'Date', 'FX'
        """
        raise NotImplementedError

    def get_price(self, bar: datetime, instrument: Stock) -> float:
        key = f"{instrument.source}/{instrument.id}"
        df = self.cache[key]
        df['Date'] = pd.to_datetime(df['Date'])

        price = df.loc[df['Date'].dt.date == bar.date(), 'PX_LAST'].iloc[0]

        # Si devise différente → conversion
        if instrument.denomination_currency != self.base_currency:
            fx_key = f"FX/{instrument.denomination_currency}/{self.base_currency}"
            fx_df = self.cache[fx_key]
            fx_df['Date'] = pd.to_datetime(fx_df['Date'])
            fx = fx_df.loc[fx_df['Date'].dt.date == bar.date(), 'FX'].iloc[0]
            return price * fx

        return price

