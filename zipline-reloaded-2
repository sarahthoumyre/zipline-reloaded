from typing import Optional, Literal, Any
import pandas as pd
from datetime import datetime

# Metaclass to enforce a singleton per source
class SingletonPerSource(type):
    """
    This metaclass ensures that only one instance of a class exists per unique 'source' parameter.
    It's useful when we want to avoid reloading or duplicating resources for the same data provider.
    """
    _instances: dict[str, Any] = {}

    def __call__(cls, source: str, *args, **kwargs):
        # If the source hasn't been instantiated yet, create and store it
        if source not in cls._instances:
            cls._instances[source] = super().__call__(source, *args, **kwargs)
        # Return the existing instance for the same source
        return cls._instances[source]

# Singleton per source – ensures only one instance of MarketData exists per data source
class MarketData(metaclass=SingletonPerSource):

    # Inner class to manage both local (per instance) and global (shared) caching
    class CacheManager:
        def __init__(self):
            # Local cache: private to the instance, used for quick access in current context
            self.local_cache: dict[str, dict[str, pd.DataFrame]] = {}

            # Global cache: shared across all MarketData instances, avoids duplicate downloads
            self.global_cache: dict[str, dict[str, pd.DataFrame]] = MarketData._global_cache

        # Retrieve data from local cache if available
        def get_from_local(self, key: str) -> Optional[pd.DataFrame]:
            return self.local_cache.get(key)

        # Store data in local cache
        def set_to_local(self, key: str, data: pd.DataFrame):
            self.local_cache[key] = data

        # Retrieve data from global cache if available
        def get_from_global(self, key: str) -> Optional[pd.DataFrame]:
            return self.global_cache.get(key)

        # Store data in global cache
        def set_to_global(self, key: str, data: pd.DataFrame):
            self.global_cache[key] = data

    # Class-level global cache: shared between all MarketData instances
    _global_cache: dict = {}

    def __init__(self, source: str, source_map: Optional[dict[str, str]] = None):
        # Primary source name (e.g., "OptionMetrics", "Bloomberg", "TRTH")
        self.source = source

        # Optional mapping of asset type to default source; allows flexible multi-source setup
        self.source_map = source_map or {
            "option": "OptionMetrics",
            "future": "Bloomberg",
            "stock": "TRTH"
        }

        # Keeps track of loaded instruments (e.g., RICs) to avoid duplicate loads
        self.loaded_rics = set()

        # Stores all retrieved market data in memory
        self.data = pd.DataFrame()

        # DataFrame for mapping between identifiers (RIC ↔ Ticker ↔ Symbol)
        self.identifier_map = pd.DataFrame()

        # Instantiate cache manager to handle both local and global caching
        self.cache = self.CacheManager()

    # Loads price data for a single instrument over a specified date range
    def load_price(self, start: datetime, end: datetime, identifier: str,
                   identifier_type: Literal["ric", "ticker", "symbol"] = "ric") -> pd.DataFrame:
