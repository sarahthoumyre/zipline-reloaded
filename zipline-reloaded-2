    # Constructs a RIC (or fetches it) from option parameters: underlying, strike, maturity, type
    def get_ric_from_option_parameters(self, underlying: str, strike: float, maturity: datetime,
                                       option_type: Literal["call", "put"], source: Optional[str] = None,
                                       identifier_type: Literal["ric", "ticker", "symbol"] = "symbol") -> Optional[str]:
        pass  # To be implemented: useful for option data loaders or custom builders

    # Returns all available options for a given underlying and date
    def get_available_options(self, underlying: str, as_of: datetime,
                              source: Optional[str] = None) -> pd.DataFrame:
