class MarketData:
    def __init__(self, data: pd.DataFrame) -> None:
        self.data = data  # Assumes data is indexed by datetime with columns as asset prices or fields

    def get_data(self, current_dt: datetime) -> pd.Series:
        return self.data.loc[current_dt]


